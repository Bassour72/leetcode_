      "seed": 678980603,
      "version": 514,
      "versionNonce": 1888579771,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1765372325548,
      "link": null,
      "locked": false,
      "text": "1.Scan the expression from left to right.\n\n2.when am operator is reached, perform the operation with the\ntwo operands found on left side of the operator.\n\n3.Replace the two operands and the operator by the operation\nresult obtained.\n\n4. Continue scanning and repeat the procedure.\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1.Scan the expression from left to right.\n\n2.when am operator is reached, perform the operation with the\ntwo operands found on left side of the operator.\n\n3.Replace the two operands and the operator by the operation\nresult obtained.\n\n4. Continue scanning and repeat the procedure.\n",
      "autoResize": true,
      "lineHeight": 1.25
    },

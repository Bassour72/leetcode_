void Core::handleCgiEvent(struct kevent e)
{
    Client *client = ClientHandler::getClient(_cgiFds[e.ident]);
    
std::cout
    << "ident=" << e.ident
    << " filter=" << e.filter
    << " flags=" << e.flags
    << std::endl;
    if (!client)
    {
        RemoveCgiEvents(e.ident);
        CleanupCGI(e.ident);
        return;
    }
    if (e.filter == EVFILT_READ)
    {    
        std::cout << "[EVFILT_READ] ===================> " << e.filter <<"\n";
        HandleCGIRead(client, e.ident);
        return;
    }
    if (e.filter == EVFILT_TIMER)
    {
        std::cout << "[TIMEOUT] ===================> " << e.filter <<"\n";
        HandleCGITimeout(client, e.ident);
        return;
    }

  
}


Core::CgiResponse Core::ParseCgiResponse(const std::string &raw)
{
    CgiResponse response;

    size_t pos = raw.find("\r\n\r\n");
    size_t sepLen = 4;

    if (pos == std::string::npos)
    {
        pos = raw.find("\n\n");
        sepLen = 2;
    }

    if (pos == std::string::npos)
    {
        // error cgi response
        return response;
    }

    std::string headerPart = raw.substr(0, pos);
    response.body = raw.substr(pos + sepLen);

    std::stringstream ss(headerPart);
    std::string line;

    while (std::getline(ss, line))
    {
        if (!line.empty() && line[line.size() - 1] == '\r')
            line.erase(line.size() - 1);

        size_t colon = line.find(':');

        if (colon == std::string::npos)
            continue;

        std::string key = line.substr(0, colon);
        std::string value = line.substr(colon + 1);

        while (!value.empty() && value[0] == ' ')
            value.erase(0, 1);

        response.headers[key] = value;
    }

    return response;
}

std::string Core::ParserClientCgiHeader(std::string &rawBuffer, int ContentLength)

{
	(void)ContentLength;
	CgiResponse cgi = ParseCgiResponse(rawBuffer);

	std::string http;

	http += "HTTP/1.1 200 OK\r\n";

	if (cgi.headers.count("Content-Type"))
		http += "Content-Type: " + cgi.headers["Content-Type"] + "\r\n";
	else
		http += "Content-Type: text/plain\r\n";

	if (cgi.headers.count("Set-Cookie"))
		http += "Set-Cookie: " + cgi.headers["Set-Cookie"] + "\r\n";

	http += "Content-Length: " + num_to_str(cgi.body.size()) + "\r\n";
	http += "Connection: close\r\n";
	http += "\r\n";
    std::cout << "{SIZE} << " << cgi.body.size() << "{SIZE}\n\n";
	http += cgi.body;
	return http;
}


int Core::ReadClientCgiDataFromPipe(int fd, std::string &buffer)
{
    char buf[RECV_CGI_BUFFER_SIZE];
    ssize_t bytesRead;
    int total = 0;
	std::memset(buf, 0,  sizeof(buf));
    while ((bytesRead = read(fd, buf, sizeof(buf))) > 0)
    {
        buffer.append(buf, bytesRead);
        total += bytesRead;
    }
    if (bytesRead < 0)
    {
        perror("read");
        return -1;
    }

    return total;
}


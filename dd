Core::CGIState Core::WaitForCGI(int fd)
{

    int status;
	pid_t pid = waitpid(_cgiPids[fd], &status, WNOHANG);
    if (pid > 0)
    {
        if (WIFEXITED(status))
        {
            int exit_code = WEXITSTATUS(status);
            if (exit_code != 0)
                return CGI_FAILED;
            else
                return CGI_RUNNING; 
        }
    }

    if (pid == 0)
        return CGI_FINISHED;
    return CGI_FINISHED;

}

void Core::HandleCGIRead(Client *client, int fd)
{
    std::string output;

    int bytes = ReadClientCgiDataFromPipe(fd, output);

    if (bytes < 0)
    {
        HandleCGIError(client, fd);
        return;
    }

    CGIState state = WaitForCGI(fd);
    if (state == NOT_CGI)
    {    
        std::cout << "[WARRING]#######################################> " << "NOT_CGI " <<"\n";
        return;
    }
    else if (state == CGI_RUNNING)
    {    
        std::cout << "[WARRING]#######################################> " << "CGI_RUNNING " <<"\n";
        std::string response = "";
        if (client->getResBuff().empty())
        {    
            response = BuildHTTPResponse(output);
             client->setResBuff(response);
        }
        else
        {
            std::string temp = client->getBodyBuff();
            temp += output;
            response = temp;
            client->setResBuff(response);
        }
        return;
    }

    else if (state == CGI_FAILED)
    {
		std::cout << "[WARRING]#######################################> " << "CGI FAILED " <<"\n";
        HandleCGIError(client, fd);
        return;
    }
    else if (state == CGI_FINISHED)
    {
        // std::cout << "[OUTPUT] ===================> " << output<<"\n";
        std::cout << "[WARRING]#######################################> " << "CGI_FINISHED " <<"\n";
        std::string response = "";
        if (client->getResBuff().empty())
        {    response = BuildHTTPResponse(output);
             client->setResBuff(response);
        }
        else
        {
            std::string temp = client->getBodyBuff();
            temp += output;
            response = temp;
            client->setResBuff(response);
        }

        RemoveCgiEvents(fd);

        ClientHandler::toggleSocketWriteEvents(_cgiFds[fd], true); //todo try to catch the excption

        CleanupCGI(fd);
    }

}


void Core::HandleCGITimeout(Client *client, int fd)
{
    KillCGI(fd);

    RemoveCgiEvents(fd);

    CleanupCGI(fd);

    ClientHandler::error_func(*client, "Request Timeout under cgi", "408");

    ClientHandler::toggleSocketWriteEvents(_cgiFds[fd], true);
}

void Core::HandleCGIError(Client *client, int fd)
{
    RemoveCgiEvents(fd);

    CleanupCGI(fd);

    ClientHandler::error_func(*client, "Internal Server Error under cgi", "500");
    try
    {
        ClientHandler::toggleSocketWriteEvents(_cgiFds[fd], true); //todo try to catch the excption
    }
    catch(...)
    {
        // std::cerr << e.what() << '\n';
    }
    
}


void Core::CleanupCGI(int fd)
{
    close(fd);

    _cgiFds.erase(fd);

    _cgiPids.erase(fd);
}


void Core::KillCGI(int fd)
{
    if (_cgiPids.find(fd) == _cgiPids.end())
        return;

    kill(_cgiPids[fd], SIGTERM);

    waitpid(_cgiPids[fd], NULL, 0);
}






